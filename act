   </div>

   <script>
      // IDs de cada sección en el mismo orden que los <li>
      const secciones = ['inicio', 'educacion', 'ingenieria', 'clima', 'ods', 'tierra', 'reciclaje', 'medioambiente', 'alumno'];

      function mostrar(id) {
         // Ocultar todas las secciones
         secciones.forEach(s => {
            document.getElementById(s).classList.remove('visible');
         });
  
         // Quitar clase activo de todos los <li>
         document.querySelectorAll('.menu1 li').forEach(li => {
            li.classList.remove('activo');
         });

         // Mostrar la sección elegida
         document.getElementById(id).classList.add('visible');

         // Marcar el <li> correspondiente como activo
         const indice = secciones.indexOf(id);
         document.querySelectorAll('.menu1 li')[indice].classList.add('activo');
      }
   </script>

</body>
</html>
